{
    "id": "gitk01n.sub",
    "name": "gitk01n脚本订阅",
    "author": "@gitk01n",
    "icon": "",
    "repo": "",
    "apps": [
        {
            "id": "gitk01n_QingLong",
            "name": "自动同步青龙面板配置",
            "author": "@gitk01n",
            "repo": "",
            "icons": [
                "https://qn.whyour.cn/logo.png",
                "https://qn.whyour.cn/logo.png"
            ],
            "keys": [
                "QL_HOST",
                "QL_ID",
                "QL_SEC",
                "AUTO_SYNC"
            ],
            "inject": {
                "boxjs": "https://raw.githubusercontent.com/gitk01n/quantumultx/refs/heads/main/script/qlSync.js"
            },
            "settings": [
                {
                    "id": "QL_HOST",
                    "name": "青龙面板地址",
                    "val": "",
                    "type": "textarea",
                    "autoGrow": true,
                    "rows": 1,
                    "desc": "示例：http://127.0.0.1:5700，末尾不要带 /"
                },
                {
                    "id": "QL_ID",
                    "name": "青龙 Client ID",
                    "val": "",
                    "type": "textarea",
                    "autoGrow": true,
                    "rows": 1,
                    "desc": "填写青龙应用的 Client ID"
                },
                {
                    "id": "QL_SEC",
                    "name": "青龙 Client Secret",
                    "val": "",
                    "type": "textarea",
                    "autoGrow": true,
                    "rows": 1,
                    "desc": "填写青龙应用的 Client Secret"
                },
                {
                    "id": "AUTO_SYNC",
                    "name": "🔁 自动实时同步",
                    "val": false,
                    "type": "boolean",
                    "desc": "开启后：保存变量时自动上传到青龙，无需手动执行"
                }
            ]
        }
    ]
}
